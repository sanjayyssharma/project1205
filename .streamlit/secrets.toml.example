# Streamlit Cloud → App settings → Secrets (paste as TOML)

# Required for recommendations (in-process backend)
GROQ_API_KEY = "gsk_..."

# Default: run backend inside Streamlit (no separate FastAPI host)
BACKEND_MODE = "local"

# First deploy: rows to ingest from Hugging Face if Parquet is missing (500–2000 is reasonable)
INGEST_LIMIT = "500"

# Optional
# GROQ_MODEL = "llama-3.1-8b-instant"
# MAX_CANDIDATES_FOR_LLM = "50"

# Split deploy only: remote FastAPI
# BACKEND_MODE = "http"
# BACKEND_URL = "https://your-api.onrender.com"
