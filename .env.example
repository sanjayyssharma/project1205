# Copy to `.env` and adjust. Do not commit `.env`.

# Hugging Face dataset for restaurant rows (Phase 1).
# HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation

# Optional git revision for reproducible loads (commit hash or tag).
# HF_DATASET_REVISION=

# Local cache for downloads and derived artifacts (Phase 1).
# CACHE_DIR=.cache/restaurant_recs

# LLM backend label (Phase 3 uses Groq when GROQ_API_KEY is set).
# LLM_PROVIDER=groq

# Max restaurants sent to the LLM after filtering (1–500).
# MAX_CANDIDATES_FOR_LLM=50

# --- Groq (Phase 3) — https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=2048

# Prompt guardrail: max total characters in system+user messages before calling Groq (413 if exceeded).
# LLM_MAX_PROMPT_CHARS=120000

# Groq HTTP client: timeout (seconds) and OpenAI SDK max retries (exponential backoff).
# GROQ_TIMEOUT_SECONDS=60
# GROQ_MAX_RETRIES=3

# Optional: max POST /v1/recommendations per client IP per rolling minute (0 = disabled).
# API_RATE_LIMIT_PER_MINUTE=0

# --- Phase 4 API ---
# Optional override for restaurants.parquet (defaults to CACHE_DIR/phase1/restaurants.parquet).
# RESTAURANT_SNAPSHOT_PATH=

# Comma-separated browser origins, or * for permissive local dev.
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Phase 7 Streamlit (httpx server-side client) ---
# Base URL of the Phase 4 API (no trailing /v1). Same variable name as Next rewrites in web/.
# BACKEND_URL=http://127.0.0.1:8000
# API_BASE_URL=   # alias; BACKEND_URL wins if both set in client
